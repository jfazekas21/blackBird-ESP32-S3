// Read the PCF8563, convert to millisecond‐since‐Unix‐epoch
static uint64_t read_rtc_epoch_ms(i2c_dev_t *dev)
{
    struct tm tm;
    uint8_t centis;
    if (pcf8563_get_time_ms(dev, &tm, &centis) != ESP_OK) {
        return UINT64_MAX; // signal error
    }
    // tm is in local‐calendar form, convert to time_t
    tm.tm_year -= 1900;      // struct tm expects years since 1900
//    tm.tm_mon  -= 1;         // struct tm expects months 0–11
    time_t secs = mktime(&tm);
    // centis is hundredths of a second (0–99), so:
    uint64_t ms = (uint64_t)secs * 1000ULL + (uint64_t)centis * 10ULL;
    return ms;
}

///
/// Read RTC until two consecutive readings differ by <1 ms.
/// @param dev    your pcf8563 device handle
/// @param out_ms pointer to receive the stable timestamp (ms since epoch)
/// @return ESP_OK on success, ESP_FAIL if RTC read error
///
esp_err_t get_stable_rtc_time_ms(i2c_dev_t *dev, uint64_t *out_ms)
{
    if (!dev || !out_ms) return ESP_ERR_INVALID_ARG;

    uint64_t t_prev = read_rtc_epoch_ms(dev);
    if (t_prev == UINT64_MAX) return ESP_FAIL;

    for (;;) {
//        vTaskDelay(pdMS_TO_TICKS(1));  // give bus a moment (optional)
        uint64_t t_cur = read_rtc_epoch_ms(dev);
        if (t_cur == UINT64_MAX) return ESP_FAIL;

        // if difference < 1 ms, we consider it stable
        if (t_cur >= t_prev) {
            if ((t_cur - t_prev) < 1) {
                *out_ms = t_cur;
                return ESP_OK;
            }
        } else {
            // handle rare wrap or clock‐set event: reset prev
            t_prev = t_cur;
        }
        t_prev = t_cur;
    }
}

// NTP sync task
static void NTP_Sync_Check(void *pvParameters)
{
	struct timeval currentTime;
	int64_t RTC_Epoch = 0, ESP_RTC = 0;
	int milliseconds = 0, RTC_milliseconds = 0;
	struct timeval delta = {0};
	struct tm timeinfo;
	struct tm RTC_time = {0};
	uint8_t timems = 0;
	time_t tOfDay = 0;
	sntp_sync_status_t sync_status = SNTP_SYNC_STATUS_RESET;
	AMessage_st s_Message_Rx;
	s_Message_Rx.Dest_ID_a8 = NTP;
	s_Message_Rx.Src_ID_u8 = CONSOLE;
	s_Message_Rx.payload_p8 = (uint8_t*) Callback_buffer;
	s_Message_Rx.payload_size = 0;
	s_Message_Rx.ucMessageID_u16 = 0;
	strcpy((char*)s_Message_Rx.cmdFun_a8,"EVENT");
	strcpy((char*)s_Message_Rx.dest_Actor_a8,"NTP");
	strcpy((char*)s_Message_Rx.src_Actor_a8,"CONSOLE");
	i2c_dev_t *dev = pcf8563_get_device_handle();

    // Initialize SNTP
//    esp_sntp_setoperatingmode(SNTP_OPMODE_POLL);
//    esp_sntp_set_sync_mode(SNTP_SYNC_MODE_IMMED); // Enable slewing
//    ntp_Para.RTC_Status = SNTP_SYNC_MODE_IMMED;    // RTC change reason is NTP immediate mode
//    const char *servers[] = NTP_SERVERS;
//    static int current_server_idx = 0;
//    for (int i = 0; i < sizeof(servers) / sizeof(servers[0]); i++) {
//        esp_sntp_setservername(i, servers[i]);
//    }
//    esp_sntp_set_time_sync_notification_cb(time_sync_notification_cb);
//    esp_sntp_init();
    ntp_initialized = true;
    record_boot_time_base();
    // Main sync loop
    while (true) {
        // Determine polling interval
        int poll_interval_s = (sync_cycle_count < INITIAL_SYNC_CYCLES) ?
                             INITIAL_POLL_INTERVAL_S : STEADY_POLL_INTERVAL_S;

        // Collect NTP samples
        ntp_sample_t samples[NTP_QUERY_COUNT];
        collect_ntp_samples(samples, NTP_QUERY_COUNT);

        uint64_t rtcMs;
        get_stable_rtc_time_ms(dev, &rtcMs);
//		if (pcf8563_get_time_ms(dev, &RTC_time, &timems) == ESP_OK) {
//
//		}
//		RTC_time.tm_year-=1900;
//		tOfDay = mktime(&RTC_time);
//
//		RTC_milliseconds = timems * 10;
		RTC_Epoch = rtcMs;

		gettimeofday(&currentTime, NULL);
		ESP_RTC =  ((uint64_t)currentTime.tv_sec * 1000) + (currentTime.tv_usec / 1000);

		cJSON *root = cJSON_CreateObject();
		cJSON_AddNumberToObject(root, "RTC_EPOC(mS)", RTC_Epoch);
		cJSON_AddNumberToObject(root, "NTP_EPOC(mS)", ESP_RTC);
		int64_t difference = (RTC_Epoch - ESP_RTC);
		cJSON_AddNumberToObject(root, "DIFFERENCE(mS)", difference);

//		if(difference > 20)
		{
	        // Select best sample
	        int64_t best_offset_us, best_rtt_us;
	        bool sync_success = select_best_sample(samples, NTP_QUERY_COUNT, &best_offset_us, &best_rtt_us);

	        double mean_rtt, std_dev_rtt;
	        if (sync_success) {
	            // Log stats for debugging
	            calculate_stats(samples, NTP_QUERY_COUNT, &mean_rtt, &std_dev_rtt);
	            int64_t error_bound_us = best_rtt_us / 2;
	//            printf("Selected: Offset=%lld us, RTT=%lld us, Error bound=%lld us, Mean RTT=%f us, Std Dev RTT=%f us \n",
	//                     best_offset_us, best_rtt_us, error_bound_us, mean_rtt, std_dev_rtt);

	            // Update offset history
	            update_offset_history(best_offset_us);

	            // Log NTP and RTC times with difference
	            int64_t drift_us = (currentTime.tv_sec - tOfDay) * 1000000LL + (currentTime.tv_usec - (RTC_milliseconds*10000));
	            float drift_ppm = (float)drift_us / poll_interval_s / 1000000.0 * 1000000.0;
	//            printf("Estimated RTC drift: %.2f ppm \n", drift_ppm);


	            // Handle large offsets
//	            if (llabs(best_offset_us) > 1000000) { // > 1 s
//	//                printf("Large offset %lld us, forcing step sync \n", best_offset_us);
//	                esp_sntp_set_sync_mode(SNTP_SYNC_MODE_IMMED);
//	                esp_sntp_restart();
//	                esp_sntp_set_sync_mode(SNTP_SYNC_MODE_SMOOTH);
//	            }

	            // TODO: Update external RTC with synchronized time
		//	    	printf("Start difference between esp rtc and external rtc = %lld \n", llabs(ESP_RTC -RTC_Epoch));


		            // 3. Write to external RTC
		             if (is_offset_valid(best_offset_us))
		             {
		 //             1. Get current system time after NTP sync
						 gettimeofday(&currentTime, NULL);
//						 int milliseconds = (currentTime.tv_usec / 1000);
						 // 2. Convert to broken-down time (if needed by RTC)
						 gmtime_r(&currentTime.tv_sec, &timeinfo);  // convert epoch sec to sec,min,hr,day,month,year format
						timeinfo.tm_year = timeinfo.tm_year + 1900 ;
						pcf8563_set_time_ms(dev, &timeinfo, (currentTime.tv_usec / 10000));
						get_current_rtc_time_ms(1);
						// Send response to the console
				        cJSON_AddNumberToObject(root, "BEST RTT(uS)", best_rtt_us);
				        cJSON_AddNumberToObject(root, "BEST OFFSET(uS)", best_offset_us);
						cJSON_AddBoolToObject(root, "ADJUSTMENT APPLIED", true);

	            //    time_t now = tv_now.tv_sec;
	            //    struct tm *tm_info = gmtime(&now); // Use gmtime for UTC
	            // 3. Write to external RTC (e.g., DS3231 via I2C)
	            //    - Initialize I2C driver if not already done (e.g., i2c_master_init())
	            //    - Use RTC driver or I2C commands to set time
	            //    Example for DS3231:
	            //    - Write registers 0x00-0x06 (seconds, minutes, hours, day, date, month, year)
	            //    - Format: BCD, e.g., tm_info->tm_sec -> (tm_info->tm_sec % 10) | ((tm_info->tm_sec / 10) << 4)
	            //    - Handle I2C errors and log failures
	            //    Pseudo-code:
	            //    i2c_cmd_handle_t cmd = i2c_cmd_link_create();
	            //    i2c_master_start(cmd);
	            //    i2c_master_write_byte(cmd, (DS3231_ADDR << 1) | I2C_MASTER_WRITE, true);
	            //    i2c_master_write_byte(cmd, 0x00, true); // Start at seconds register
	            //    i2c_master_write_byte(cmd, dec_to_bcd(tm_info->tm_sec), true);
	            //    i2c_master_write_byte(cmd, dec_to_bcd(tm_info->tm_min), true);
	            //    i2c_master_write_byte(cmd, dec_to_bcd(tm_info->tm_hour), true);
	            //    ...
	            //    i2c_master_stop(cmd);
	            //    esp_err_t ret = i2c_master_cmd_begin(I2C_NUM_0, cmd, pdMS_TO_TICKS(1000));
	            //    i2c_cmd_link_delete(cmd);
	            //    if (ret != ESP_OK) {
	            //        printf("Failed to update external RTC");
	            //    }
	            }
	            else
	            {
	                               // Trigger immediate retry
	                    poll_interval_s = 1;
	//                    printf("Offset %lld us is suspicious, skipping RTC update \n", best_offset_us);
	            }
	            // 4. Only update if sync is valid to avoid unnecessary writes

	            // Update drift estimate (simple moving average)
	            if (last_offset_us != 0) {
	                int64_t interval_us = poll_interval_s * 1000000LL;
	                int64_t drift_us = best_offset_us - last_offset_us;
	                avg_drift_us_per_s = (avg_drift_us_per_s * 3 + drift_us / poll_interval_s) / 4;
	//                printf("Estimated drift: %lld us/s \n", avg_drift_us_per_s);
	            }
	            last_offset_us = best_offset_us;

	            // Adjust polling interval if drift is high
	            if (llabs(avg_drift_us_per_s) > 10) { // >10 us/s (~1 ms/min)
	//            	printf("High drift detected, reducing poll interval \n");
	                sync_cycle_count = 0; // Trigger fast polling
	            }
	        } else {
	            cJSON_AddNumberToObject(root, "BEST RTT(uS)", -1);
	            cJSON_AddNumberToObject(root, "BEST OFFSET(uS)", -1);
	    		cJSON_AddBoolToObject(root, "ADJUSTMENT APPLIED", false);
	//        	printf("Sync failed, trying next server \n");
//	            current_server_idx = (current_server_idx + 1) % (sizeof(servers) / sizeof(servers[0]));
//	            esp_sntp_stop();
//	            esp_sntp_setservername(0, servers[current_server_idx]);
//	            esp_sntp_init();
				poll_interval_s = 1; // Immediate retry

	//			// Read external RTC and write to internal RTC
	//			if (pcf8563_get_time_ms(dev, &RTC_time, &timems) == ESP_OK) {
	//				RTC_time.tm_year-=1900;
	//				tOfDay = mktime(&RTC_time);
	//			}
	//			currentTime.tv_sec = tOfDay;
	//			currentTime.tv_usec = timems * 10000;
	//			settimeofday(&currentTime, NULL);
	        }
	        cJSON_AddNumberToObject(root, "MEAN RTT(uS)", mean_rtt);
	        cJSON_AddNumberToObject(root, "STD DEV RTT(uS)", std_dev_rtt);
		}

		memset(payLoadData_NTP,0,sizeof(payLoadData_NTP));
		cJSON_PrintPreallocated(root, payLoadData_NTP, sizeof(payLoadData_NTP), false);
		strcpy((char*)s_Message_Rx.payload_p8, payLoadData_NTP);
		cJSON_Delete(root);
		console_send_responce_to_console_xface(&s_Message_Rx);
        sync_cycle_count++;
        vTaskDelay(pdMS_TO_TICKS(poll_interval_s * 1000));
    }
}


