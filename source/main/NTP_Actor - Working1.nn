// Function to select the best NTP sample
static bool select_best_sample(ntp_sample_t *samples, int count, int64_t *best_offset_us, int64_t *best_rtt_us)
{
    double median = calculate_median_rtt(samples, count);
    double cutoff = median * RTT_OUTLIER_THRESHOLD;
    printf("Median RTT=%.1f us, cutoff=%.1f us\n", median, cutoff);

    int64_t min_rtt = INT64_MAX;
    int     best_i  = -1;

    for (int i = 0; i < count; i++) {
        if (!samples[i].valid) continue;
        if ((double)samples[i].rtt_us > cutoff) {
            printf( "Sample %d: RTT %lld us > cutoff\n", i+1, samples[i].rtt_us);
            continue;
        }
        if (samples[i].rtt_us < min_rtt) {
            min_rtt = samples[i].rtt_us;
            best_i  = i;
        }
    }
    if (best_i < 0) {
        printf("No valid samples after filtering\n");
        return false;
    }
    *best_offset_us = samples[best_i].offset_us;
    *best_rtt_us    = samples[best_i].rtt_us;
    return true;
}

void sntp_sync_time(struct timeval *tv)
{
    uint8_t time_ms;
    printf("\n\n\n\n\nSHOULD NOT COME SNTP SYNC TIME\n\n\n\n\n");
    if (sntp_get_sync_mode() == SNTP_SYNC_MODE_IMMED) {
        settimeofday(tv, NULL);
        sntp_set_sync_status(SNTP_SYNC_STATUS_COMPLETED);
    } else if (sntp_get_sync_mode() == SNTP_SYNC_MODE_SMOOTH) {
        struct timeval tv_now;
        i2c_dev_t *rtcHandle = pcf8563_get_device_handle();
        struct tm time = {0};
        pcf8563_get_time_ms(rtcHandle, &time, &time_ms);
        time.tm_year -= 1900;
        time_t tOfDay = mktime(&time);
        tv_now.tv_sec = tOfDay;
        tv_now.tv_usec = time_ms * 10000; // 1 centisecond = 10ms = 10,000us

        int64_t cpu_time = (int64_t)tv_now.tv_sec * 1000000L + (int64_t)tv_now.tv_usec;
        int64_t sntp_time = (int64_t)tv->tv_sec * 1000000L + (int64_t)tv->tv_usec;
        int64_t delta = sntp_time - cpu_time;
        struct timeval tv_delta = { .tv_sec = delta / 1000000L, .tv_usec = delta % 1000000L };
        if (adjtime(&tv_delta, NULL) == -1) {
            printf("Function adjtime don't update time because the error is very big\n");
            settimeofday(tv, NULL);
            printf("Time was synchronized through settimeofday\n");
            sntp_set_sync_status(SNTP_SYNC_STATUS_COMPLETED);
        } else {
            sntp_set_sync_status(SNTP_SYNC_STATUS_IN_PROGRESS);
        }
    }
}

