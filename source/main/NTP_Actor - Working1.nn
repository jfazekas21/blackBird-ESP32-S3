// Function to set an initial time
static void set_initial_time(AMessage_st* s_Message_Rx) {
    cJSON *in_JSON 		= NULL;
    struct timeval currentTime;
    char str[200] = {0};
	in_JSON 		= cJSON_Parse((char*) s_Message_Rx->payload_p8);
	if (in_JSON == NULL) {
		sprintf(str,"Invalid Json input at %d in %s",__LINE__,__FUNCTION__);
		Add_Response_msg(str,s_Message_Rx);
	}

	cJSON *commandKey = cJSON_GetObjectItem(in_JSON, "EPOCH_MILLS");
	if((commandKey!=NULL) && cJSON_IsNumber(commandKey) )
	{
		uint64_t epochUTCmilliseconds=commandKey->valuedouble;
		currentTime.tv_sec =  (epochUTCmilliseconds)/1000L;
		currentTime.tv_usec = ((epochUTCmilliseconds%1000)*1000);
	}
	cJSON_Delete(in_JSON);
    // Get the current time
    struct timeval now;
    gettimeofday(&now, NULL);

    // Set time only if current time is less than the initial time
//    if (abs((int)now.tv_sec - (int)currentTime.tv_sec) >= 30)   //120
    {
    	settimeofday(&currentTime, NULL);
    	Add_Response_msg("Internal RTC time is set.",s_Message_Rx);
        //ESP_LOGI("TIME", "System time set to initial time");
    } 
//    else {
//        ESP_LOGI("TIME", "System time is already ahead of initial time, no change made");
//    }
}


static void NTP_Connect(void *pvParameters __attribute__((unused)))
{
	AMessage_st* s_Message_Rx = (AMessage_st*)pvParameters;
	AMessage_st s_Message_Rx_data;
	char data_buffer[200] = {0}, payLoadData_NTP[200] = {0};
	memset(data_buffer,0,sizeof(data_buffer));
	memcpy(&s_Message_Rx_data, s_Message_Rx, sizeof(AMessage_st));
	s_Message_Rx_data.payload_p8 = (uint8_t*)data_buffer;
    strcpy((char*)s_Message_Rx_data.src_Actor_a8, "CONSOLE");
    strcpy((char*)s_Message_Rx_data.dest_Actor_a8, "NTP");
    strcpy((char*)s_Message_Rx_data.cmdFun_a8, "CONNECT");

	char count = 0, display_msg = 0;
	cJSON *my_JSON1  	= cJSON_CreateArray();
	cJSON_AddItemToArray(my_JSON1, cJSON_CreateString("NET_STATUS"));
	cJSON *jsonObject = cJSON_CreateObject();
	cJSON_AddItemToObject(jsonObject, "Property_Names", my_JSON1);
	memset(payLoadData_NTP,0,sizeof(payLoadData_NTP));
	cJSON_PrintPreallocated(jsonObject, payLoadData_NTP, sizeof(payLoadData_NTP), false);
	cJSON_Delete(jsonObject);
	Send_CMD_To_Other_Actor(CONSOLE,"CONSOLE", payLoadData_NTP, strlen(payLoadData_NTP), "GET");

	while(1)
	{
		if(NET_status == E_NET_CONNECTED)
		{
			strcpy(ntp_Para.URL,(const char*)"pool.ntp.org");
			strcpy(ntp_Para.time_zone,(const char*)"UTC");
//			ntp_Para.sync_interval=60000;
//			initialize_sntp();
			Add_Response_msg("Connected to NTP",&s_Message_Rx_data);
			NTP_operation = 1;
		}
		else
		{
			count++;
			if((count > 100) && (display_msg == 0))
			{
				display_msg = 1;
				Add_Response_msg("Kindly connect to internet at first.",&s_Message_Rx_data);
				ConnectHandle = NULL;
				vTaskDelete(ConnectHandle);
			}
		}
		if(NTP_operation == 1)
		{
			ConnectHandle = NULL;
			vTaskDelete(ConnectHandle);  // Delete the task
		}
		vTaskDelay(10 / portTICK_PERIOD_MS);
	}
}
static void Send_CMD_To_Other_Actor(char dest_id, const char *DestActor, char *response, int16_t size, char *function)
{
	AMessage_st s_Message_Tx_new;
	uint8_t *newpointer  		= (uint8_t*) heap_caps_calloc((strlen(response)+1),sizeof(uint8_t),MALLOC_CAP_SPIRAM | MALLOC_CAP_8BIT); //strlen((char*)out_val + 1)
	if (newpointer == NULL)
	{
		printf("Memory allocation failed\n");
		return;
	}
	strcpy((char*)newpointer, response);
	s_Message_Tx_new.payload_p8 	=  newpointer;
	s_Message_Tx_new.Dest_ID_a8 = dest_id;
	s_Message_Tx_new.payload_size = size;  //0 , size;  // if you don't want to free payload at dest actor then give payload size =0
	s_Message_Tx_new.ucMessageID_u16 = ++s_Message_Tx.ucMessageID_u16; //s_Message_Tx.ucMessageID_u16;
	strcpy((char*) s_Message_Tx_new.src_Actor_a8	, THIS_ACTOR);
	strcpy((char*) s_Message_Tx_new.dest_Actor_a8	, DestActor);
	strcpy((char*) s_Message_Tx_new.cmdFun_a8		, function);
	console_ActorWriteToConsole_xface( &s_Message_Tx_new);
} //	COP_add_response_to_COP_Tx_Queue


static void Add_Response_msg(char* buffer, AMessage_st* s_Message_Rx)
{
	cJSON *responseObject = cJSON_CreateObject();  	// Create a RESPONSE object and add it to the RESPONSE array
	cJSON_AddStringToObject(responseObject, "RESP", buffer);
	memset(payLoadData,0,sizeof(payLoadData));//\0';
	cJSON_PrintPreallocated(responseObject, payLoadData, sizeof(payLoadData), false);
	strcpy((char*)s_Message_Rx->payload_p8, payLoadData);		
	console_send_responce_to_console_xface(s_Message_Rx);
	cJSON_Delete(responseObject);
}

static void Set_NTP_Sync_Interval(AMessage_st* s_Message_Rx)
{
    cJSON *in_JSON 		= NULL;
    char str[200] = {0};
	in_JSON 		= cJSON_Parse((char*) s_Message_Rx->payload_p8);
	if (in_JSON == NULL) {
		sprintf(str,"Invalid JSON input at %d in %s",__LINE__,__FUNCTION__);
		Add_Response_msg(str,s_Message_Rx);
	}

	cJSON *SYNC_INTERVAL = cJSON_GetObjectItem(in_JSON, "SYNC_INTERVAL");
	if((SYNC_INTERVAL!=NULL) && cJSON_IsNumber(SYNC_INTERVAL) )
	{
		ntp_Para.sync_interval = SYNC_INTERVAL->valueint;
		sntp_set_sync_interval(ntp_Para.sync_interval);
		sprintf(str,"NTP sync interval is set to %ld.", ntp_Para.sync_interval);
		Add_Response_msg(str,s_Message_Rx);
	}
	cJSON_Delete(in_JSON);
}




// Configuration
#define NTP_SERVERS {"pool.ntp.org", "north-america.pool.ntp.org", "time.google.com"}
#define NTP_QUERY_COUNT 5         // Number of queries per sync cycle
#define INITIAL_POLL_INTERVAL_S 20 // Initial sync interval (seconds)
#define STEADY_POLL_INTERVAL_S 60 // Steady-state sync interval (seconds)
#define INITIAL_SYNC_CYCLES 8     // Number of fast initial sync cycles
#define RTT_OUTLIER_THRESHOLD 1.2 //1.5 // Discard RTTs > median * threshold
#define OFFSET_OUTLIER_THRESHOLD 300000 //3000// Discard offsets > 5 ms from average
#define MAX_RTT_MS 5000           // Ignore samples with RTT > 5s
#define TASK_PRIORITY (tskIDLE_PRIORITY + 5) // High-priority task
#define OFFSET_HISTORY_SIZE 8     // Sliding window for offset validation
#define ABSOLUTE_OFFSET_THRESHOLD_US  (500LL * 1000LL)  // 50 ms absolute cap during first N cycles
#define WARMUP_CYCLES             3               // how many cycles to accept large offsets
#define WARMUP_ABSOLUTE_CAP_US  5000000L          // 5 seconds cap during warm-up
#define WARMUP_RTT_THRESHOLD_US  (200 * 1000)  // 200 ms
// Structure to hold NTP sample data
typedef struct {
    int64_t offset_us; // Clock offset in microseconds
    int64_t rtt_us;    // Approximate round-trip time in microseconds
    bool valid;        // Sample validity
} ntp_sample_t;

// Global variables
static volatile bool ntp_initialized = false;
static int64_t last_offset_us = 0;
static int64_t avg_drift_us_per_s = 0;
static int sync_cycle_count = 0;
static int64_t offset_history[OFFSET_HISTORY_SIZE] = {0};
static int offset_history_idx = 0;
static int offset_history_count = 0;

// Function to calculate median RTT
static float calculate_median_rtt(ntp_sample_t *samples, int count)
{
    double values[NTP_QUERY_COUNT];
    int n = 0;

    for (int i = 0; i < count; i++) {
        if (samples[i].valid) {
            values[n++] = (double)samples[i].rtt_us;
        }
    }
    if (n == 0) {
        printf("No valid RTTs to median\n");
        return 0.0;
    }

    // Simple insertion sort for small n
    for (int i = 1; i < n; i++) {
        double key = values[i];
        int j = i - 1;
        while (j >= 0 && values[j] > key) {
            values[j + 1] = values[j];
            j--;
        }
        values[j + 1] = key;
    }

    if (n % 2 == 0) {
        return (values[n/2 - 1] + values[n/2]) * 0.5;
    } else {
        return values[n/2];
    }
}

// Function to calculate mean offset from history
static int64_t calculate_mean_offset(void)
{
    if (offset_history_count == 0) return 0;
    int64_t sum = 0;
    for (int i = 0; i < offset_history_count; i++) {
        sum += offset_history[i];
    }
    return sum / offset_history_count;
}

// Function to update offset history
static void update_offset_history(int64_t offset_us)
{
    offset_history[offset_history_idx] = offset_us;
    offset_history_idx = (offset_history_idx + 1) % OFFSET_HISTORY_SIZE;
    if (offset_history_count < OFFSET_HISTORY_SIZE) {
        offset_history_count++;
    }
}



static bool is_offset_valid(int64_t offset_us) {
    int64_t abs_offset = llabs(offset_us);

    // Warmup cycles: allow large offsets up to WARMUP_ABSOLUTE_CAP_US
    if (sync_cycle_count < WARMUP_CYCLES) {
        if (abs_offset > WARMUP_ABSOLUTE_CAP_US) {
            printf("Cycle %d: Offset %lld us exceeds warmup cap %lld us\n",
                   sync_cycle_count, (long long)offset_us, (long long)WARMUP_ABSOLUTE_CAP_US);
            return false;
        }
        printf("Cycle %d: Warmup, accepting offset %lld us\n",
               sync_cycle_count, (long long)offset_us);
        return true;
    }

    // Initial cycles: cap at ABSOLUTE_OFFSET_THRESHOLD_US
    if (sync_cycle_count < INITIAL_SYNC_CYCLES) {
        if (abs_offset > ABSOLUTE_OFFSET_THRESHOLD_US) {
            printf("Cycle %d: Offset %lld us exceeds initial cap %lld us\n",
                   sync_cycle_count, (long long)offset_us, (long long)ABSOLUTE_OFFSET_THRESHOLD_US);
            return false;
        }
        printf("Cycle %d: Initial cycle, accepting offset %lld us\n",
               sync_cycle_count, (long long)offset_us);
        return true;
    }

    // Normal operation: compare against mean of history
    if (offset_history_count < OFFSET_HISTORY_SIZE) {
        printf("Cycle %d: history %d/%d not full, accepting offset %lld us\n",
               sync_cycle_count, offset_history_count, OFFSET_HISTORY_SIZE, (long long)offset_us);
        return true;
    }

    int64_t mean = calculate_mean_offset();
    int64_t delta = llabs(offset_us - mean);
    if (delta > OFFSET_OUTLIER_THRESHOLD) {
        printf("Offset %lld us deviates from mean %lld us by %lld us (> %d us), rejecting\n",
               (long long)offset_us, (long long)mean, (long long)delta, OFFSET_OUTLIER_THRESHOLD);
        return false;
    }

    printf("Offset %lld us within threshold (mean=%lld us ±%d us)\n",
           (long long)offset_us, (long long)mean, OFFSET_OUTLIER_THRESHOLD);
    return true;
}

// Function to calculate mean and standard deviation of RTTs (for logging)
static void calculate_stats(ntp_sample_t *samples, int count, double *mean_rtt, double *std_dev_rtt)
{
    double sum = 0.0;
    int n = 0;
    for (int i = 0; i < count; i++) {
        if (samples[i].valid) {
            sum += (double)samples[i].rtt_us;
            n++;
        }
    }
    *mean_rtt = (n > 0) ? (sum / n) : 0.0;

    double var = 0.0;
    for (int i = 0; i < count; i++) {
        if (samples[i].valid) {
            double d = (double)samples[i].rtt_us - *mean_rtt;
            var += d * d;
        }
    }
    *std_dev_rtt = (n > 1) ? sqrt(var / (n - 1)) : 0.0;
}


#define NTP_PORT             "123"
#define NTP_PACKET_SIZE      48
#define NTP_TIMESTAMP_DELTA  2208988800UL  // seconds between 1900 & 1970
#define MAX_RTT_MS           5000          // as in your other code
static int64_t  boot_time_epoch_us;    // microseconds since 1970 at boot
static int64_t  boot_time_uptime_us;   // esp_timer_get_time() at same moment

// Call once at program start, after SNTP has set the clock at least once
static void record_boot_time_base(void) {
    struct timeval tv;
    gettimeofday(&tv, NULL);
    boot_time_epoch_us  = (int64_t)tv.tv_sec * 1000000LL + tv.tv_usec;
    boot_time_uptime_us = esp_timer_get_time();
}
// One raw‐UDP NTP exchange, with detailed timing breakdown.
// Perform one raw‐UDP NTP exchange, compute offset & RTT correctly.
// Perform one raw‐UDP NTP exchange, using monotonic uptimes for T1/T4.
// Returns false on failure, true on success and fills *offset_us and *rtt_us.
static bool ntp_raw_sample(const char *server, int64_t *offset_us, int64_t *rtt_us) {
    struct addrinfo hints = { .ai_family = AF_INET, .ai_socktype = SOCK_DGRAM };
    struct addrinfo *res = NULL;
    if (getaddrinfo(server, NTP_PORT, &hints, &res) != 0 || res == NULL) {
        printf("ntp_raw_sample: DNS lookup failed (%s)\n", server);
        return false;
    }

    int sock = socket(res->ai_family, res->ai_socktype, 0);
    if (sock < 0) {
        printf("ntp_raw_sample: socket() failed\n");
        freeaddrinfo(res);
        return false;
    }

    uint8_t pkt[NTP_PACKET_SIZE] = {0};
    pkt[0] = 0x1B;  // LI=0, VN=3, Mode=3 (client)

    // 1) Capture monotonic T1
    int64_t t1 = esp_timer_get_time();

    sendto(sock, pkt, NTP_PACKET_SIZE, 0, res->ai_addr, res->ai_addrlen);

    fd_set rfds;
    FD_ZERO(&rfds);
    FD_SET(sock, &rfds);
    struct timeval tv = { .tv_sec = 3, .tv_usec = 0 };
    if (select(sock+1, &rfds, NULL, NULL, &tv) <= 0) {
        close(sock);
        freeaddrinfo(res);
        return false;
    }

    recvfrom(sock, pkt, NTP_PACKET_SIZE, 0, NULL, NULL);

    // 2) Capture monotonic T4
    int64_t t4 = esp_timer_get_time();

    close(sock);
    freeaddrinfo(res);

    // 3) extract server transmit timestamp (T3) in NTP seconds+fraction
    uint32_t tx_secs = ntohl(*(uint32_t*)&pkt[40]);
    uint32_t tx_frac = ntohl(*(uint32_t*)&pkt[44]);

    double server_time_s = (double)(tx_secs - NTP_TIMESTAMP_DELTA)
                        + ((double)tx_frac / (1ULL<<32));
    int64_t server_time_us = (int64_t)(server_time_s * 1e6);

    // 4) convert server_time_us (epoch) into our monotonic time base:
    //    monotonic_us = boot_uptime_us + (server_epoch_us - boot_epoch_us)
    int64_t t3 = boot_time_uptime_us + (server_time_us - boot_time_epoch_us);

    // 5) compute RTT and offset in monotonic µs
    *rtt_us    = t4 - t1;
    *offset_us = t3 - ((t1 + t4)/2);

    return true;
}

// Collect NTP samples exactly as before, using the corrected helper
static void collect_ntp_samples(ntp_sample_t *samples, int count)
{
    const char *servers[] = NTP_SERVERS;
    int nservers = sizeof(servers) / sizeof(servers[0]);

    for (int i = 0; i < count; i++) {
        samples[i].valid = false;
        int si = i % nservers;
        printf("collect_ntp_samples: Sample #%d → server \"%s\"\n", i+1, servers[si]);

        int64_t offs = 0, rtt = 0;
        bool ok = ntp_raw_sample(servers[si], &offs, &rtt);

        if (!ok) {
            printf("collect_ntp_samples: Sample #%d failed\n", i+1);

        // **NEW**: during the first few cycles, drop any RTT > 200 ms outright
        } else if (sync_cycle_count < WARMUP_CYCLES && rtt > WARMUP_RTT_THRESHOLD_US) {
            printf("collect_ntp_samples: Sample #%d RTT %lld us > warm-up threshold %d us, rejecting\n",
                   i+1, (long long)rtt, WARMUP_RTT_THRESHOLD_US);

        } else if (rtt < 0 || rtt > MAX_RTT_MS * 1000) {
            printf("collect_ntp_samples: Sample #%d invalid RTT=%lld us\n", i+1, (long long)rtt);

        } else if (!is_offset_valid(offs)) {
            printf("collect_ntp_samples: Sample #%d offset=%lld us rejected by filter\n",
                   i+1, (long long)offs);

        } else {
            samples[i].offset_us = offs;
            samples[i].rtt_us    = rtt;
            samples[i].valid     = true;
            update_offset_history(offs);
            printf("collect_ntp_samples: Sample #%d VALID offset=%lld us, RTT=%lld us\n",
                   i+1, (long long)offs, (long long)rtt);
        }

        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}
