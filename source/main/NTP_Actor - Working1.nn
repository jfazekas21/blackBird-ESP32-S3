#ifdef CONFIG_SNTP_TIME_SYNC_METHOD_CUSTOM
void sntp_sync_time(struct timeval *tv)
{
   settimeofday(tv, NULL);
#ifdef ENABLE_PRINT_MSG
   printf("Time is synchronized from custom code");
#endif
   sntp_set_sync_status(SNTP_SYNC_STATUS_COMPLETED);
}
#endif

static void initialize_sntp(void) {
    NTP_sync_time();

    if (esp_sntp_enabled()) {
        return;
    } else {
        esp_sntp_setoperatingmode(SNTP_OPMODE_POLL);
        esp_sntp_setservername(0, ntp_Para.URL);
        esp_sntp_setservername(1, "time.google.com");
	    esp_sntp_setservername(2, "time.windows.com");   // Tertiary NTP server

//        sntp_set_sync_mode(SNTP_SYNC_MODE_SMOOTH);
//        ntp_Para.NTP_Mode = SNTP_SYNC_MODE_SMOOTH;
        sntp_set_sync_mode(SNTP_SYNC_MODE_IMMED);
        ntp_Para.NTP_Mode = SNTP_SYNC_MODE_IMMED;
        // Perform initial quick sync
//        sntp_set_time_sync_notification_cb(time_sync_notification_cb);
        esp_sntp_init();

        // 5) Prime state
        burst_count     = 0;
        in_fast_burst   = true;
        rtc_written     = false;

        // Wait for the initial sync to complete (you might want to add a mechanism to ensure this)
        while (sntp_get_sync_status() != SNTP_SYNC_STATUS_COMPLETED) {
            vTaskDelay(2000 / portTICK_PERIOD_MS);
        }
    }
}

void NTP_sync_time(void)
{
	sntp_set_sync_interval(ntp_Para.sync_interval);
	if (sntp_restart()==1)
	{
		NTPstatus = SNTP_SYNC_STATUS_RESET;
	}
}



